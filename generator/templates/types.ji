    }

    public static readonly LoreStore Invalid = default;

    public void Dispose() {}
}

[StructLayout(LayoutKind.Sequential)]
public unsafe struct LoreBytes : IDisposable
{
    IntPtr ptr;
    nuint len;

    public LoreBytes(byte[] input)
    {
        input = input ?? Array.Empty<byte>();
        ptr = Marshal.AllocHGlobal(input.Length);
        Marshal.Copy(input, 0, ptr, input.Length);
        len = (nuint)input.Length;
    }

    public static implicit operator LoreBytes(byte[] input)
    {
        return new LoreBytes(input);
    }

    public static byte[] ToNative(LoreBytes input)
    {
        if (input.ptr == IntPtr.Zero) return Array.Empty<byte>();
        if (input.len == 0) return Array.Empty<byte>();

        var buffer_view = new ReadOnlySpan<byte>((void*)input.ptr, (int)input.len);
        return buffer_view.ToArray();
    }

    public void Dispose()
    {
        if (ptr != IntPtr.Zero)
        {
            Marshal.FreeHGlobal(ptr);
            ptr = IntPtr.Zero;
            len = 0;
        }
    }
}

{% for arr in array_types %}
[StructLayout(LayoutKind.Sequential)]
public unsafe struct {{ arr.array_class }} : IDisposable
{
    IntPtr {{ arr.ptr_field }};
    nuint {{ arr.count_field }};

    public {{ arr.array_class }}({{ arr.element_cs_type }}[] input)
    {
        input = input ?? Array.Empty<{{ arr.element_cs_type }}>();
        nint element_size = Marshal.SizeOf<{{ arr.marshal_size_type }}>();
        {{ arr.ptr_field }} = Marshal.AllocHGlobal(element_size * input.Length);
        var buffer_view = new Span<{{ arr.element_class }}>((void*){{ arr.ptr_field }}, input.Length);
        for (int i = 0; i < input.Length; ++i)
{% if arr.category == "primitive_bool" %}
            buffer_view[i] = input[i] ? (byte)1 : (byte)0;
{% elif arr.category == "native_wrapper" %}
            buffer_view[i] = new {{ arr.element_class }}(input[i]);
{% else %}
            buffer_view[i] = input[i];
{% endif %}
        {{ arr.count_field }} = (nuint)input.Length;
    }

    public static implicit operator {{ arr.array_class }}({{ arr.element_cs_type }}[] input)
    {
        return new {{ arr.array_class }}(input);
    }

    public static {{ arr.element_cs_type }}[] ToNative({{ arr.array_class }} input)
    {
        if (input.{{ arr.ptr_field }} == IntPtr.Zero) return Array.Empty<{{ arr.element_cs_type }}>();
        if (input.{{ arr.count_field }} == 0) return Array.Empty<{{ arr.element_cs_type }}>();

        var buffer_view = new ReadOnlySpan<{{ arr.element_class }}>((void*)input.{{ arr.ptr_field }}, (int)input.{{ arr.count_field }});
{% if arr.category == "primitive_bool" %}
        var result = new bool[buffer_view.Length];
        for (int i = 0; i < buffer_view.Length; ++i)
            result[i] = buffer_view[i] != 0;
        return result;
{% elif arr.category == "native_wrapper" %}
        var result = new {{ arr.element_cs_type_base }}[buffer_view.Length]{{ arr.element_cs_type_rank }};
        for (int i = 0; i < buffer_view.Length; ++i)
            result[i] = {{ arr.to_native_call | replace("{element}", "buffer_view[i]") }};
        return result;
{% else %}
        return buffer_view.ToArray();
{% endif %}
    }

    public void Dispose()
    {
        if ({{ arr.ptr_field }} != IntPtr.Zero)
        {
{% if arr.category == "native_wrapper" or arr.category == "struct" %}
            var buffer_view = new Span<{{ arr.element_class }}>((void*){{ arr.ptr_field }}, (int){{ arr.count_field }});
            for (int i = 0; i < buffer_view.Length; ++i)
                buffer_view[i].Dispose();

{% endif %}
            Marshal.FreeHGlobal({{ arr.ptr_field }});
            {{ arr.ptr_field }} = IntPtr.Zero;
            {{ arr.count_field }} = 0;
        }
    }
}

{% endfor %}

[StructLayout(LayoutKind.Sequential)]
internal struct _LoreEventCallbackConfig
{
    public ulong userContext;
    public LoreInternalCallback func;
}

public class LoreEventCallbackConfig{
    public ulong UserContext { get; set; }
    public LoreCallback Func { get; set; } = (LoreEventFFI loreEvent, ulong userContext) => {};
}

{% for struct_name, struct_fields in symbols.types.items() %}
    {% set class_name = pascal_case(struct_name.removesuffix("_t")) %}
    {% if struct_name not in hardcoded_blit_classes %}
        [StructLayout(LayoutKind.Sequential)]
        public unsafe struct {{ class_name }} : IDisposable
        {
            {% for field in struct_fields %}
                {% set field_type = field.0 %}
                {% set field_name = field.1.replace("string", "string_") %}
                {% set field_array_size = field.2 %}

                {% if field_array_size != 0 %}
                    {% set field_type = field_type.removesuffix("_t") + "_array_t" %}
                {% endif %}

                {% if field_type not in blit_types and field_type in cs_map %}
                    {% set field_type = cs_map[field_type] %}
                {% endif %}

                {% if field_type in utils.cs_allowed_fixed and field_array_size != 0 %}
                    private const uint {{ field_name }}Size = {{ field_array_size }};
                    private fixed {{ field_type }} {{ field_name }}[{{ field_array_size }}];
                {% elif field_type in blit_types %}
                    private {{ pascal_case(field_type.removesuffix("_t")) }} {{ field_name }};
                {% else %}
                    private {{ field_type }} {{ field_name }};
                {% endif %}
            {% endfor %}

            {% for field in struct_fields %}
                {% set field_type = field.0 %}
                {% set field_name = field.1 %}
                {% set field_array_size = field.2 %}

                {% if field_array_size != 0 %}
                    {% set field_type = field_type.removesuffix("_t") + "_array_t" %}
                {% endif %}

                {% set prop_type = cs_map[field_type] %}
                {% if field_type in ["lore_hash_t", "lore_context_t", "lore_branch_point_t", "lore_partition_t", "lore_branch_id_t", "lore_repository_id_t", "lore_instance_id_t"] %}
                    {% set prop_type = pascal_case(field_type.removesuffix("_t")) %}
                {% endif %}

                {% if field.3 %}
                    /**
                    * <summary>
                    * {{ "\n* ".join(field.3).replace("<", "&lt;").replace(">", "&gt;") }}
                    * </summary>
                    */
                {% endif %}
                {% if prop_type == "byte" %}
                    public bool {{ pascal_case(field_name) }} {
                        set => {{ field_name }} = Convert.ToByte(value);
                        get => Convert.ToBoolean({{ field_name }});
                    }
                {% else %}
                    public {{ prop_type }} {{ pascal_case(field_name) }} {
                        {% if field_type in blit_types and field_type not in ["lore_hash_t", "lore_context_t", "lore_branch_point_t", "lore_partition_t", "lore_branch_id_t", "lore_repository_id_t", "lore_instance_id_t", "lore_address_t", "lore_fragment_t", "lore_metadata_t"] %}
                            set {
                                {{ field_name }}.Dispose();
                                {{ field_name }} = value;
                            }
                            get => {{ pascal_case(field_type.removesuffix("_t")) }}.ToNative({{ field_name }});
                        {% else %}
                            set => {{ field_name }} = value;
                            get => {{ field_name }};
                        {% endif %}
                    }
                {% endif %}
            {% endfor %}

            public {{ class_name }} Clone() => this;

            public void Dispose()
            {
                {% for field in struct_fields %}
                    {% set field_type = field.0 %}
                    {% set field_name = field.1 %}
                    {% set field_array_size = field.2 %}
                    {% if field_array_size != 0 %}
                        {% set field_type = field_type.removesuffix("_t") + "_array_t" %}
                    {% endif %}
                    {% if field_type in blit_types %}
                        {{ field_name }}.Dispose();
                    {% endif %}
                {% endfor %}
            }
        }
    {% endif %}
{% endfor %}

[StructLayout(LayoutKind.Explicit)]
public struct LoreMetadata
{
    [FieldOffset(0)] private LoreMetadataTag tag;
    {% for field in symbols.types["lore_metadata_t"] %}
        {% set field_type = field.0 %}
        {% set field_name = field.1.replace("string", "string_") %}

        {% if field_type not in blit_types and field_type in cs_map %}
            [FieldOffset(8)] private {{ cs_map[field_type] }} {{ field_name }};
        {% elif field_type in blit_types %}
            [FieldOffset(8)] private {{ pascal_case(field_type.removesuffix("_t")) }} {{ field_name }};
        {% else %}
            [FieldOffset(8)] private {{ field_type }} {{ field_name }};
        {% endif %}
    {% endfor %}

    public LoreMetadataTag Tag
    {
        get => tag;
    }

    public LoreAddress Address
    {
        get => address;
    }
    public bool Boolean
    {
        get => Convert.ToBoolean(boolean);
    }
    public byte[] Binary
    {
        get => LoreBinary.ToNative(binary);
    }
    public LoreContext Context
    {
        get => context;
    }
    public LoreHash Hash
    {
        get => hash;
    }
    public ulong Numeric
    {
        get => numeric;
    }
    public string String
    {
        get => LoreString.ToNative(string_);
    }

    public LoreMetadata Clone()
    {
        var result = this;

        // Deep-copy variants that hold unmanaged pointers (IntPtr)
        switch (tag)
        {
            case LoreMetadataTag.BINARY:
                Unsafe.As<ulong, LoreBinary>(
                    ref Unsafe.Add(ref Unsafe.As<LoreMetadata, ulong>(ref result), 1)
                ) = new LoreBinary(LoreBinary.ToNative(binary));
                break;
            case LoreMetadataTag.STRING:
                Unsafe.As<ulong, LoreString>(
                    ref Unsafe.Add(ref Unsafe.As<LoreMetadata, ulong>(ref result), 1)
                ) = new LoreString(LoreString.ToNative(string_));
                break;
        }

        return result;
    }
}