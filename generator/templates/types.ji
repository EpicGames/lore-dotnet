{% import "utils.ji" as utils %}

{#

LoreCallback represents the delegate that already Marshalled the payload into
the corresponding event. This provides the user with the friendlier C# API.

#}

public delegate void LoreCallback(LoreEventFFI loreEvent, ulong userContext);

{#

LoreInternalCallback is the internal representation of the lorelib expected callback.
It has all the information provided by lorelib and will internally call the user-provided
callback after Marshalling the payload.

#}

[UnmanagedFunctionPointer(CallingConvention.Cdecl)]
internal unsafe delegate void LoreInternalCallback(_LoreEvent* loreEvent, ulong userContext);

{#

Generate blittable types for foundational types, this are the types that we need to ultimately generate in order to make a call to lorelib.
The blittable types are also in charge of disposing any unamanged resources and/or creating a managed C# type from it.
Default access is internal as the blittable types should be only used from within the SDK. Only exception being the IsSet types.

For instance, for the `struct LoreString`

    typedef struct LoreString {
        const char *string;
        uintptr_t length;
    } LoreString;

the result is:

    [StructLayout(LayoutKind.Sequential)]
    internal unsafe struct LoreString : IDisposable
    {
        public IntPtr string_;
        public nuint length;

        public static LoreString ToBlittable(string input)
        {
            input = input ?? string.Empty;
            byte[] input_encoded = Encoding.UTF8.GetBytes(input);
            IntPtr buffer = Marshal.AllocHGlobal(input_encoded.Length);
            Marshal.Copy(input_encoded, 0, buffer, input_encoded.Length);
            return new LoreString { string_ = buffer, length = (nuint)input_encoded.Length };
        }

        public void Dispose()
        {
            if (string_ != IntPtr.Zero)
            {
                Marshal.FreeHGlobal(string_);
                string_ = IntPtr.Zero;
                length = 0;
            }
        }

        public static string FromBlittable(LoreString input)
        {
            if (input.string_ == IntPtr.Zero)
                return string.Empty;
            if (input.length == 0)
                return string.Empty;

            var buffer_view = new ReadOnlySpan<byte>((void*)input.string_, (int)input.length);
            return Encoding.UTF8.GetString(buffer_view);
        }
    }

#}

[StructLayout(LayoutKind.Sequential)]
public unsafe struct LoreHash : IDisposable
{
    private const int dataSize = 32;
    private fixed byte data[dataSize];

    public LoreHash(byte[] input)
    {
        if (input == null)
        {
            Console.WriteLine("Input is null. Returning default.");
            return;
        }

        fixed(byte* src = input)
        fixed (byte* dst = data)
        {
            if (input.Length > dataSize)
            {
                Console.WriteLine("Input length bigger than expected. Truncating.");
                Buffer.MemoryCopy(src, dst, dataSize, dataSize);
                return;
            }

            if (input.Length < dataSize)
            {
                Console.WriteLine("Input length smaller than expected. Padding with default.");
            }
            Buffer.MemoryCopy(src, dst, dataSize, input.Length);
        }
    }

    public static implicit operator LoreHash(byte[] input)
    {
        return new LoreHash(input);
    }

    public byte[] Data {
        get {
            fixed(byte* buffer = data)
            {
                var buffer_view = new ReadOnlySpan<byte>(buffer, dataSize);
                return buffer_view.ToArray();
            }
        }
    }

    public void Dispose() {}
}

[InlineArray(2)]
public unsafe struct LoreHashArray : IDisposable
{
    public LoreHash parent0;

    public LoreHashArray(byte[][] input)
    {
        if (input != null && input.Length > 0) this[0] = new LoreHash(input[0]);
        if (input != null && input.Length > 1) this[1] = new LoreHash(input[1]);
    }

    public static implicit operator LoreHashArray(byte[][] input)
    {
        return new LoreHashArray(input);
    }

    public static byte[][] ToNative(LoreHashArray input)
    {
        var parent = new byte[2][];
        parent[0] = input[0].Data;
        parent[1] = input[1].Data;
        return parent;
    }

    public void Dispose() {}
}

