[StructLayout(LayoutKind.Sequential)]
public unsafe struct LoreString : IDisposable
{
    IntPtr string_;
    nuint length;

    public LoreString(string input)
    {
        input = input ?? string.Empty;
        byte[] input_encoded = Encoding.UTF8.GetBytes(input);
        string_ = Marshal.AllocHGlobal(input_encoded.Length);
        Marshal.Copy(input_encoded, 0, string_, input_encoded.Length);
        length = (nuint)input_encoded.Length;
    }

    public static implicit operator LoreString(string input)
    {
        return new LoreString(input);
    }

    public static string ToNative(LoreString input)
    {
        if (input.string_ == IntPtr.Zero) return string.Empty;
        if (input.length == 0) return string.Empty;

        var buffer_view = new ReadOnlySpan<byte>((void*)input.string_, (int)input.length);
        return Encoding.UTF8.GetString(buffer_view);
    }

    public void Dispose()
    {
        if (string_ != IntPtr.Zero)
        {
            Marshal.FreeHGlobal(string_);
            string_ = IntPtr.Zero;
            length = 0;
        }
    }
}

[StructLayout(LayoutKind.Sequential)]
public unsafe struct LoreBinary : IDisposable
{
    IntPtr payload;
    nuint length;

    public LoreBinary(byte[] input)
    {
        input = input ?? Array.Empty<byte>();
        payload = Marshal.AllocHGlobal(input.Length);
        Marshal.Copy(input, 0, payload, input.Length);
        length = (nuint)input.Length;
    }

    public static byte[] ToNative(LoreBinary input)
    {
        if (input.payload == IntPtr.Zero) return Array.Empty<byte>();
        if (input.length == 0) return Array.Empty<byte>();

        var buffer_view = new ReadOnlySpan<byte>((void*)input.payload, (int)input.length);
        return buffer_view.ToArray();
    }

    public void Dispose()
    {
        if (payload != IntPtr.Zero)
        {
            Marshal.FreeHGlobal(payload);
            payload = IntPtr.Zero;
            length = 0;
        }
    }
}

